# Knowledge Master Configuration
# Copy to .env and modify as needed

# API key for REST endpoint authentication (optional — disabled if not set)
# KM_API_KEY=your-secret-key-here

# FalkorDB connection
# KM_FALKORDB_HOST=localhost
# KM_FALKORDB_PORT=6379

# Ollama embedding model
# KM_EMBED_MODEL=nomic-embed-text
# KM_OLLAMA_HOST=http://localhost:11434

# Web UI port
# KM_PORT=9999
